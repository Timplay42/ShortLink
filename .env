#DB
DB_DRIVER=postgresql+asyncpg
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5433
DB_NAME=short_link
DB_URL=postgresql+asyncpg://postgres:postgres@db:5433/short_link
DB_WAIT_MAX_ATTEMPTS=15
DB_WAIT_SLEEP_SECONDS=2

REDIS_PASSWORD=redis
REDIS_USER=redis
REDIS_USER_PASSWORD=redis
REDIS_PATH="redis://redis"
REDIS_DB=1

LENGTH_SHORT_ID=10
LENGTH_TITLE=50
LENGTH_DESCRIPTION=500